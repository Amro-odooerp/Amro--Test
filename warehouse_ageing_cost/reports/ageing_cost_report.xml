<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_ageing_cost_report" model="ir.actions.act_window">
        <field name="name">Ageing Cost Report</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('state', '=', 'done'), ('ageing_cost', '>', 0)]</field>
        <field name="context">{'search_default_done': 1}</field>
    </record>

    <menuitem id="menu_ageing_cost_report"
        name="Ageing Cost Report"
        action="action_ageing_cost_report"
        parent="stock.menu_stock_report"
        sequence="50"/>
</odoo>
