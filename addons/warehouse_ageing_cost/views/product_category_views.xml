<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_category_form_view_ageing" model="ir.ui.view">
        <field name="name">product.category.form.ageing</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <group string="Warehouse Ageing Cost">
                    <field name="daily_storage_rate"/>
                    <field name="handling_dispatch_fee"/>
                    <field name="ageing_in_cogs"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
