<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_move_list_view_ageing" model="ir.ui.view">
        <field name="name">stock.move.list.ageing</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_qty']" position="after">
                <field name="days_stored"/>
                <field name="ageing_cost"/>
            </xpath>
        </field>
    </record>

    <record id="stock_warehouse_form_view_ageing" model="ir.ui.view">
        <field name="name">stock.warehouse.form.ageing</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="daily_storage_rate"/>
            </xpath>
        </field>
    </record>
</odoo>
