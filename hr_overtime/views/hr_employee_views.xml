<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend Employee Form View -->
    <record id="hr_employee_view_form_inherit_overtime" model="ir.ui.view">
        <field name="name">hr.employee.form.overtime</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_overtime" type="object"
                        class="oe_stat_button" icon="fa-clock-o">
                    <div class="o_stat_info">
                        <field name="overtime_count" class="o_stat_value"/>
                        <span class="o_stat_text">Overtime</span>
                    </div>
                </button>
            </div>
        </field>
    </record>

    <!-- Employee Overtime Smart Button shows details -->
    <record id="hr_employee_view_form_inherit_overtime_details" model="ir.ui.view">
        <field name="name">hr.employee.form.overtime.details</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Overtime" name="overtime_page">
                    <group>
                        <group string="Current Month Summary">
                            <field name="total_overtime_hours" widget="float_time"/>
                            <field name="total_overtime_amount" widget="monetary"/>
                            <field name="pending_overtime_count"/>
                        </group>
                    </group>
                    <group string="Recent Overtime Records">
                        <field name="overtime_ids" nolabel="1" mode="tree"
                               context="{'default_employee_id': active_id}">
                            <tree string="Overtime" create="0" edit="0" delete="0" limit="10">
                                <field name="name"/>
                                <field name="date"/>
                                <field name="overtime_type_id"/>
                                <field name="duration" widget="float_time"/>
                                <field name="overtime_amount" widget="monetary"/>
                                <field name="state" widget="badge"/>
                                <field name="currency_id" invisible="1"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
