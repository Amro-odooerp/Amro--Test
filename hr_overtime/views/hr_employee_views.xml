<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Employee Form View -->
    <record id="hr_employee_view_form_overtime" model="ir.ui.view">
        <field name="name">hr.employee.form.overtime</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_overtime" type="object" 
                        class="oe_stat_button" icon="fa-clock-o">
                    <field name="overtime_count" widget="statinfo" string="Overtime"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Employee Overtime Tab (Alternative: Add tab in employee form) -->
    <record id="hr_employee_view_form_overtime_tab" model="ir.ui.view">
        <field name="name">hr.employee.form.overtime.tab</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Overtime" name="overtime">
                    <group>
                        <group>
                            <field name="total_overtime_hours" widget="float_time"/>
                        </group>
                        <group>
                            <field name="total_overtime_amount"/>
                        </group>
                    </group>
                    <field name="overtime_ids" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="overtime_type_id"/>
                            <field name="duration" widget="float_time"/>
                            <field name="overtime_amount"/>
                            <field name="state" widget="badge"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
