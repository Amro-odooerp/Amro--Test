<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Overtime Type Tree View -->
    <record id="hr_overtime_type_view_tree" model="ir.ui.view">
        <field name="name">hr.overtime.type.tree</field>
        <field name="model">hr.overtime.type</field>
        <field name="arch" type="xml">
            <tree string="Overtime Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="rate"/>
                <field name="active"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Overtime Type Form View -->
    <record id="hr_overtime_type_view_form" model="ir.ui.view">
        <field name="name">hr.overtime.type.form</field>
        <field name="model">hr.overtime.type</field>
        <field name="arch" type="xml">
            <form string="Overtime Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Weekend Overtime"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="rate"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Description of this overtime type..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Overtime Type Search View -->
    <record id="hr_overtime_type_view_search" model="ir.ui.view">
        <field name="name">hr.overtime.type.search</field>
        <field name="model">hr.overtime.type</field>
        <field name="arch" type="xml">
            <search string="Search Overtime Types">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Overtime Type Action -->
    <record id="hr_overtime_type_action" model="ir.actions.act_window">
        <field name="name">Overtime Types</field>
        <field name="res_model">hr.overtime.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first overtime type
            </p>
            <p>
                Define different types of overtime with their rate multipliers.
                For example: Regular Overtime (1.5x), Weekend (2x), Holiday (2.5x).
            </p>
        </field>
    </record>
</odoo>
