<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for overtime records -->
    <data noupdate="1">
        <record id="seq_hr_overtime" model="ir.sequence">
            <field name="name">HR Overtime Sequence</field>
            <field name="code">hr.overtime</field>
            <field name="prefix">OT/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>

    <!-- Form View -->
    <record id="hr_overtime_view_form" model="ir.ui.view">
        <field name="name">hr.overtime.view.form</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <form string="Overtime Request">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" states="draft"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-primary" states="submitted"
                            groups="hr.group_hr_manager"/>
                    <button name="action_refuse" string="Refuse" type="object"
                            class="btn-danger" states="submitted"
                            groups="hr.group_hr_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            states="draft,submitted"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            states="refused,cancelled"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="contract_id"/>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Overtime Details">
                            <field name="date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="hours" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="overtime_type" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="overtime_rate"/>
                        </group>
                    </group>
                    <group>
                        <group string="Wage Calculation Settings">
                            <field name="working_days_per_month" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="working_hours_per_day" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        </group>
                        <group string="Calculated Amounts">
                            <field name="currency_id" invisible="1"/>
                            <field name="employee_wage"/>
                            <field name="hourly_rate"/>
                            <field name="overtime_hourly_rate"/>
                            <label for="overtime_amount"/>
                            <div class="oe_inline">
                                <field name="overtime_amount" class="oe_inline"/>
                                <span class="oe_grey oe_inline"> (Total Overtime Pay)</span>
                            </div>
                        </group>
                    </group>
                    <group string="Additional Information">
                        <field name="description" attrs="{'readonly': [('state', '!=', 'draft')]}"
                               placeholder="Enter any additional details about this overtime..."/>
                    </group>
                    <group string="Approval Information" attrs="{'invisible': [('state', 'not in', ['approved', 'refused'])]}">
                        <field name="approved_by"/>
                        <field name="approved_date"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="hr_overtime_view_tree" model="ir.ui.view">
        <field name="name">hr.overtime.view.tree</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <tree string="Overtime Requests" decoration-success="state=='approved'"
                  decoration-danger="state=='refused'" decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date"/>
                <field name="hours" sum="Total Hours"/>
                <field name="overtime_type"/>
                <field name="overtime_rate"/>
                <field name="employee_wage"/>
                <field name="hourly_rate"/>
                <field name="overtime_amount" sum="Total Amount"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state == 'refused'"
                       decoration-info="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="hr_overtime_view_search" model="ir.ui.view">
        <field name="name">hr.overtime.view.search</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <search string="Search Overtime">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date"/>
                <filter string="My Overtime" name="my_overtime"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Refused" name="refused" domain="[('state', '=', 'refused')]"/>
                <separator/>
                <filter string="Regular Overtime" name="regular" domain="[('overtime_type', '=', 'regular')]"/>
                <filter string="Weekend Overtime" name="weekend" domain="[('overtime_type', '=', 'weekend')]"/>
                <filter string="Holiday Overtime" name="holiday" domain="[('overtime_type', '=', 'holiday')]"/>
                <filter string="Night Shift" name="night" domain="[('overtime_type', '=', 'night')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '>=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last Month" name="last_month"
                        domain="[('date', '>=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Overtime Type" name="group_type" context="{'group_by': 'overtime_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="hr_overtime_view_pivot" model="ir.ui.view">
        <field name="name">hr.overtime.view.pivot</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <pivot string="Overtime Analysis">
                <field name="employee_id" type="row"/>
                <field name="date" type="col" interval="month"/>
                <field name="hours" type="measure"/>
                <field name="overtime_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="hr_overtime_view_graph" model="ir.ui.view">
        <field name="name">hr.overtime.view.graph</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <graph string="Overtime Analysis" type="bar">
                <field name="employee_id"/>
                <field name="overtime_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="hr_overtime_view_calendar" model="ir.ui.view">
        <field name="name">hr.overtime.view.calendar</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <calendar string="Overtime Calendar" date_start="date" color="employee_id" mode="month">
                <field name="employee_id"/>
                <field name="hours"/>
                <field name="overtime_amount"/>
            </calendar>
        </field>
    </record>

    <!-- Action -->
    <record id="hr_overtime_action" model="ir.actions.act_window">
        <field name="name">Overtime</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form,pivot,graph,calendar</field>
        <field name="search_view_id" ref="hr_overtime_view_search"/>
        <field name="context">{'search_default_approved': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first overtime request
            </p>
            <p>
                Track and calculate employee overtime wages based on their contract salary.
                Different overtime rates are available for regular, weekend, holiday, and night shift overtime.
            </p>
        </field>
    </record>

    <!-- Action for Pending Approvals -->
    <record id="hr_overtime_action_to_approve" model="ir.actions.act_window">
        <field name="name">Overtime to Approve</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="hr_overtime_view_search"/>
        <field name="domain">[('state', '=', 'submitted')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No overtime requests pending approval
            </p>
        </field>
    </record>

    <!-- Action for My Overtime -->
    <record id="hr_overtime_action_my" model="ir.actions.act_window">
        <field name="name">My Overtime</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="search_view_id" ref="hr_overtime_view_search"/>
        <field name="context">{'search_default_my_overtime': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your overtime request
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="hr_overtime_menu_root"
              name="Overtime"
              parent="hr.menu_hr_root"
              sequence="25"/>
    
    <menuitem id="hr_overtime_menu_overtime"
              name="All Overtime"
              parent="hr_overtime_menu_root"
              action="hr_overtime_action"
              sequence="10"/>
    
    <menuitem id="hr_overtime_menu_my"
              name="My Overtime"
              parent="hr_overtime_menu_root"
              action="hr_overtime_action_my"
              sequence="20"/>
    
    <menuitem id="hr_overtime_menu_to_approve"
              name="To Approve"
              parent="hr_overtime_menu_root"
              action="hr_overtime_action_to_approve"
              groups="hr.group_hr_manager"
              sequence="30"/>

</odoo>
