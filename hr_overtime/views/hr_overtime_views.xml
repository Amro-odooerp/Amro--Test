<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Overtime Tree View -->
    <record id="hr_overtime_view_tree" model="ir.ui.view">
        <field name="name">hr.overtime.tree</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <tree string="Overtime" decoration-info="state == 'draft'" 
                  decoration-warning="state == 'submitted'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="overtime_type_id"/>
                <field name="date"/>
                <field name="duration" widget="float_time"/>
                <field name="overtime_amount" sum="Total Amount"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Overtime Form View -->
    <record id="hr_overtime_view_form" model="ir.ui.view">
        <field name="name">hr.overtime.form</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <form string="Overtime">
                <header>
                    <button name="action_submit" string="Submit" type="object" 
                            states="draft" class="oe_highlight"/>
                    <button name="action_approve" string="Approve" type="object" 
                            states="submitted" class="oe_highlight"
                            groups="hr_overtime.group_hr_overtime_manager"/>
                    <button name="action_reject" string="Reject" type="object" 
                            states="submitted"
                            groups="hr_overtime.group_hr_overtime_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" 
                            states="draft,submitted"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" 
                            states="rejected,cancelled"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="department_id"/>
                            <field name="manager_id"/>
                            <field name="contract_id"/>
                        </group>
                        <group>
                            <field name="overtime_type_id"/>
                            <field name="date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <group string="Time">
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                        <group string="Calculation">
                            <field name="hourly_rate"/>
                            <field name="rate_multiplier"/>
                            <field name="overtime_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Reason for overtime work..."/>
                    </group>
                    <group states="rejected">
                        <field name="rejection_reason"/>
                    </group>
                    <group states="approved">
                        <group>
                            <field name="approved_by"/>
                            <field name="approved_date"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Overtime Calendar View -->
    <record id="hr_overtime_view_calendar" model="ir.ui.view">
        <field name="name">hr.overtime.calendar</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <calendar string="Overtime Calendar" date_start="date_start" date_stop="date_end" 
                      color="overtime_type_id" mode="month">
                <field name="employee_id"/>
                <field name="overtime_type_id"/>
                <field name="duration"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Overtime Pivot View -->
    <record id="hr_overtime_view_pivot" model="ir.ui.view">
        <field name="name">hr.overtime.pivot</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <pivot string="Overtime Analysis">
                <field name="employee_id" type="row"/>
                <field name="overtime_type_id" type="col"/>
                <field name="duration" type="measure"/>
                <field name="overtime_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Overtime Graph View -->
    <record id="hr_overtime_view_graph" model="ir.ui.view">
        <field name="name">hr.overtime.graph</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <graph string="Overtime Analysis" type="bar">
                <field name="employee_id"/>
                <field name="duration" type="measure"/>
                <field name="overtime_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Overtime Search View -->
    <record id="hr_overtime_view_search" model="ir.ui.view">
        <field name="name">hr.overtime.search</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <search string="Search Overtime">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="overtime_type_id"/>
                <separator/>
                <filter string="My Overtime" name="my_overtime" 
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="My Team" name="my_team" 
                        domain="[('employee_id.parent_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="This Month" name="this_month" 
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                ('date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last Month" name="last_month" 
                        domain="[('date', '&gt;=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                                ('date', '&lt;=', (context_today() - relativedelta(months=1, day=31)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Overtime Type" name="group_type" context="{'group_by': 'overtime_type_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Overtime Actions -->
    <record id="hr_overtime_action" model="ir.actions.act_window">
        <field name="name">Overtime</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form,calendar,pivot,graph</field>
        <field name="context">{'search_default_my_overtime': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first overtime request
            </p>
            <p>
                Track and manage overtime hours. Submit requests for approval
                and get compensated based on your overtime type rates.
            </p>
        </field>
    </record>

    <record id="hr_overtime_action_all" model="ir.actions.act_window">
        <field name="name">All Overtime</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form,calendar,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No overtime records found
            </p>
        </field>
    </record>

    <record id="hr_overtime_action_to_approve" model="ir.actions.act_window">
        <field name="name">Overtime to Approve</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'submitted')]</field>
        <field name="context">{'search_default_my_team': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No overtime requests waiting for approval
            </p>
        </field>
    </record>

    <record id="hr_overtime_action_approved" model="ir.actions.act_window">
        <field name="name">Approved Overtime</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="domain">[('state', '=', 'approved')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No approved overtime records
            </p>
        </field>
    </record>
</odoo>
