<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Overtime Manager Group -->
        <record id="group_hr_overtime_manager" model="res.groups">
            <field name="name">Overtime Manager</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="comment">Can manage all overtime records, approve/refuse requests, and configure overtime types.</field>
        </record>

        <!-- Overtime User Group -->
        <record id="group_hr_overtime_user" model="res.groups">
            <field name="name">Overtime User</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="comment">Can create and view own overtime records.</field>
        </record>

        <!-- Record Rules -->
        
        <!-- Employees can see their own overtime -->
        <record id="hr_overtime_rule_employee" model="ir.rule">
            <field name="name">Overtime: Employee sees own</field>
            <field name="model_id" ref="model_hr_overtime"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers can see their team's overtime -->
        <record id="hr_overtime_rule_manager" model="ir.rule">
            <field name="name">Overtime: Manager sees team</field>
            <field name="model_id" ref="model_hr_overtime"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hr_overtime_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- HR Overtime Managers can see all -->
        <record id="hr_overtime_rule_hr_manager" model="ir.rule">
            <field name="name">Overtime: HR Manager sees all</field>
            <field name="model_id" ref="model_hr_overtime"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_overtime_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Multi-company rule -->
        <record id="hr_overtime_rule_multi_company" model="ir.rule">
            <field name="name">Overtime: Multi-company</field>
            <field name="model_id" ref="model_hr_overtime"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

    </data>
</odoo>
