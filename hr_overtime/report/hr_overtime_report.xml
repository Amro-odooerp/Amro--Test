<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Overtime Report Template -->
    <template id="report_overtime_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Overtime Report</h2>
                    <h3 t-if="docs">
                        <span t-field="docs[0].employee_id.name"/> - Overtime Summary
                    </h3>
                    
                    <table class="table table-sm table-bordered mt-4">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Duration</th>
                                <th>Rate</th>
                                <th class="text-right">Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_hours" t-value="0"/>
                            <t t-set="total_amount" t-value="0"/>
                            <tr t-foreach="docs" t-as="o">
                                <td><span t-field="o.name"/></td>
                                <td><span t-field="o.date"/></td>
                                <td><span t-field="o.overtime_type_id.name"/></td>
                                <td><span t-field="o.duration" t-options='{"widget": "float_time"}'/></td>
                                <td><span t-field="o.rate"/>x</td>
                                <td class="text-right">
                                    <span t-field="o.overtime_amount" 
                                          t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                                <td><span t-field="o.state"/></td>
                                <t t-set="total_hours" t-value="total_hours + o.duration"/>
                                <t t-set="total_amount" t-value="total_amount + o.overtime_amount"/>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr class="font-weight-bold">
                                <td colspan="3">Total</td>
                                <td><t t-esc="'%.2f' % total_hours"/> hours</td>
                                <td></td>
                                <td class="text-right">
                                    <t t-if="docs">
                                        <span t-esc="total_amount" 
                                              t-options='{"widget": "monetary", "display_currency": docs[0].currency_id}'/>
                                    </t>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- Report Action -->
    <record id="action_report_overtime" model="ir.actions.report">
        <field name="name">Overtime Report</field>
        <field name="model">hr.overtime</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_overtime.report_overtime_document</field>
        <field name="report_file">hr_overtime.report_overtime_document</field>
        <field name="binding_model_id" ref="model_hr_overtime"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Monthly Overtime Summary Report Template -->
    <template id="report_overtime_monthly_summary">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Monthly Overtime Summary</h2>
                    
                    <div class="row mt-4 mb-4">
                        <div class="col-6">
                            <strong>Period:</strong> 
                            <span t-if="date_from" t-esc="date_from"/> - 
                            <span t-if="date_to" t-esc="date_to"/>
                        </div>
                        <div class="col-6 text-right">
                            <strong>Generated:</strong> 
                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                        </div>
                    </div>
                    
                    <table class="table table-sm table-bordered">
                        <thead class="bg-primary text-white">
                            <tr>
                                <th>Employee</th>
                                <th>Department</th>
                                <th>Regular OT</th>
                                <th>Weekend OT</th>
                                <th>Holiday OT</th>
                                <th>Total Hours</th>
                                <th class="text-right">Total Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="summary_data or []" t-as="row">
                                <td t-esc="row.get('employee')"/>
                                <td t-esc="row.get('department')"/>
                                <td t-esc="'%.2f' % row.get('regular_hours', 0)"/>
                                <td t-esc="'%.2f' % row.get('weekend_hours', 0)"/>
                                <td t-esc="'%.2f' % row.get('holiday_hours', 0)"/>
                                <td t-esc="'%.2f' % row.get('total_hours', 0)"/>
                                <td class="text-right" t-esc="'%.2f' % row.get('total_amount', 0)"/>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
